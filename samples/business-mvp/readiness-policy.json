    {"blocker_id": "B16", "reason_code": "CHEAPEST_EXPERIMENT_REQUIRED", "description": "A cheaper sufficient experiment blocks an MVP."},
    {"blocker_id": "B17", "reason_code": "BUDGET_CAP_REQUIRED", "description": "Projected cost must remain within budget."},
