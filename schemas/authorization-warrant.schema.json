{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tempo.local/schemas/authorization-warrant.schema.json",
  "title": "TEMPO Human Authorization Warrant",
  "description": "Time-bounded, scope-bounded implementation authority. The kernel must reject agent self-signing, expiry, revocation, excessive TTL, and protected-input drift.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "warrant_id",
    "mvp_ref",
    "assessment_ref",
    "repository_ref",
    "state",
    "signer_ref",
    "signer_session",
    "issued_at",
    "expires_at",
    "authorization_type",
    "allowed_actions",
    "allowed_scope",
    "allowed_lanes",
    "budget_cap",
    "deadline",
    "hash_set",
    "demo_context_hash",
    "revocation",
    "provenance_kind",
    "previous_warrant_ref"
  ],
  "properties": {
    "warrant_id": {"type": "string", "pattern": "^W-[A-Z0-9][A-Z0-9._-]{2,63}$"},
    "mvp_ref": {"type": "string", "pattern": "^M-[A-Z0-9][A-Z0-9._-]{2,63}$"},
    "assessment_ref": {"type": "string", "pattern": "^A-[A-Z0-9][A-Z0-9._-]{2,63}$"},
    "repository_ref": {"type": "string", "minLength": 1, "maxLength": 500},
    "state": {"type": "string", "enum": ["active", "revoked", "expired", "invalidated"]},
    "signer_ref": {"type": "string", "pattern": "^(human|platform):[A-Za-z0-9][A-Za-z0-9._@+:/-]{1,127}$"},
    "signer_session": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{2,255}$"},
    "issued_at": {"type": "string", "format": "date-time"},
    "expires_at": {"type": "string", "format": "date-time"},
    "authorization_type": {"type": "string", "enum": ["mvp_build", "demo_build", "pilot", "external_action", "release"]},
    "allowed_actions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "enum": ["read", "plan_write", "implementation_write", "test", "build", "local_demo", "network_access", "external_communication", "spend", "publish", "deploy", "submit"]}
    },
    "allowed_scope": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/pathGlob"}},
    "allowed_lanes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z][a-z0-9_-]{1,63}$"}},
    "budget_cap": {"$ref": "#/$defs/money"},
    "deadline": {"type": "string", "format": "date-time"},
    "hash_set": {
      "type": "object",
      "additionalProperties": false,
      "required": ["signed_decision_brief", "hypothesis_set", "evidence_manifest", "readiness_policy", "mvp_charter", "runtime_config", "budget", "deadline", "allowed_scope"],
      "properties": {
        "signed_decision_brief": {"$ref": "#/$defs/hash"},
        "hypothesis_set": {"$ref": "#/$defs/hash"},
        "evidence_manifest": {"$ref": "#/$defs/hash"},
        "readiness_policy": {"$ref": "#/$defs/hash"},
        "mvp_charter": {"$ref": "#/$defs/hash"},
        "runtime_config": {"$ref": "#/$defs/hash"},
        "budget": {"$ref": "#/$defs/hash"},
        "deadline": {"$ref": "#/$defs/hash"},
        "allowed_scope": {"$ref": "#/$defs/hash"}
      }
    },
    "demo_context_hash": {"type": ["string", "null"], "pattern": "^sha256:[a-f0-9]{64}$"},
    "revocation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["revoked", "revoked_at", "revoked_by", "reason_code"],
      "properties": {
        "revoked": {"type": "boolean"},
        "revoked_at": {"type": ["string", "null"], "format": "date-time"},
        "revoked_by": {"type": ["string", "null"], "pattern": "^(human|agent|kernel|verifier|platform):[A-Za-z0-9][A-Za-z0-9._@+:/-]{1,127}$"},
        "reason_code": {"type": ["string", "null"], "pattern": "^[A-Z][A-Z0-9_]{2,63}$"}
      }
    },
    "provenance_kind": {"type": "string", "enum": ["tty_human", "external_signer", "platform_attestation", "local_integrity_only"]},
    "previous_warrant_ref": {"type": ["string", "null"], "pattern": "^W-[A-Z0-9][A-Z0-9._-]{2,63}$"}
  },
  "allOf": [
    {
      "if": {
        "properties": {"state": {"const": "active"}},
        "required": ["state"]
      },
      "then": {
        "properties": {
          "provenance_kind": {"enum": ["tty_human", "external_signer", "platform_attestation", "local_integrity_only"]},
          "revocation": {
            "properties": {
              "revoked": {"const": false},
              "revoked_at": {"type": "null"},
              "revoked_by": {"type": "null"},
              "reason_code": {"type": "null"}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"state": {"enum": ["revoked", "expired", "invalidated"]}}, "required": ["state"]},
      "then": {
        "properties": {
          "revocation": {
            "properties": {
              "revoked": {"const": true},
              "revoked_at": {"type": "string", "format": "date-time"},
              "revoked_by": {"type": "string"},
              "reason_code": {"type": "string"}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"authorization_type": {"enum": ["external_action", "release"]}},
        "required": ["authorization_type"]
      },
      "then": {
        "properties": {
          "provenance_kind": {"enum": ["external_signer", "platform_attestation"]}
        }
      }
    },
    {
      "if": {
        "properties": {"provenance_kind": {"const": "tty_human"}},
        "required": ["provenance_kind"]
      },
      "then": {
        "properties": {
          "signer_ref": {"type": "string", "pattern": "^human:[A-Za-z0-9][A-Za-z0-9._@+:/-]{1,127}$"}
        }
      }
    },
    {
      "if": {
        "properties": {"provenance_kind": {"const": "local_integrity_only"}},
        "required": ["provenance_kind"]
      },
      "then": {
        "properties": {
          "authorization_type": {"const": "demo_build"},
          "signer_ref": {"const": "platform:demo-fixture-signer"}
        }
      }
    },
    {
      "if": {
        "properties": {"authorization_type": {"const": "demo_build"}},
        "required": ["authorization_type"]
      },
      "then": {
        "properties": {
          "provenance_kind": {"const": "local_integrity_only"},
          "signer_ref": {"const": "platform:demo-fixture-signer"},
          "demo_context_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}
        }
      }
    },
    {
      "if": {
        "properties": {"authorization_type": {"enum": ["mvp_build", "pilot", "external_action", "release"]}},
        "required": ["authorization_type"]
      },
      "then": {"properties": {"demo_context_hash": {"type": "null"}}}
    }
  ],
  "$defs": {
    "hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "pathGlob": {"type": "string", "pattern": "^(?![A-Za-z]:)(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\\u0000]+$", "maxLength": 500},
    "money": {
      "type": "object",
      "additionalProperties": false,
      "required": ["amount", "currency"],
      "properties": {
        "amount": {"type": "number", "minimum": 0},
        "currency": {"type": "string", "pattern": "^[A-Z]{3}$"}
      }
    }
  }
}
