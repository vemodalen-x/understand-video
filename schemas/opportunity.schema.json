{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tempo.local/schemas/opportunity.schema.json",
  "title": "TEMPO Business Opportunity",
  "description": "Authoritative business-decision input. Times are RFC 3339 date-time values and IDs are stable across revisions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "opportunity_id",
    "version",
    "state",
    "decision_question",
    "decision_owner",
    "decision_at",
    "initiating_context",
    "target_user",
    "economic_buyer",
    "job_to_be_done",
    "observed_problem",
    "current_alternatives",
    "expected_value",
    "strategic_context",
    "constraints",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "opportunity_id": {"type": "string", "pattern": "^O-[A-Z0-9][A-Z0-9._-]{2,63}$"},
    "version": {"type": "integer", "minimum": 1},
    "state": {
      "type": "string",
      "enum": ["DRAFT", "DISCOVERY", "VALIDATING", "MVP_CANDIDATE", "MVP_AUTHORIZED", "EXPERIMENT_REQUIRED", "PIVOTED", "KILLED"]
    },
    "decision_question": {"type": "string", "minLength": 12, "maxLength": 1000},
    "decision_owner": {"$ref": "#/$defs/actorRef"},
    "decision_at": {"type": "string", "format": "date-time"},
    "initiating_context": {"type": "string", "minLength": 1, "maxLength": 4000},
    "target_user": {"$ref": "#/$defs/party"},
    "economic_buyer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["same_as_target_user", "description", "value_recipient"],
      "properties": {
        "same_as_target_user": {"type": "boolean"},
        "description": {"type": "string", "minLength": 1, "maxLength": 2000},
        "value_recipient": {"type": "string", "minLength": 1, "maxLength": 1000}
      }
    },
    "job_to_be_done": {"type": "string", "minLength": 12, "maxLength": 2000},
    "observed_problem": {"type": "string", "minLength": 12, "maxLength": 3000},
    "current_alternatives": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "maxLength": 1000}
    },
    "expected_value": {"type": "string", "minLength": 1, "maxLength": 2000},
    "strategic_context": {"type": "string", "minLength": 1, "maxLength": 3000},
    "constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["constraint_id", "type", "description"],
        "properties": {
          "constraint_id": {"type": "string", "pattern": "^C-[A-Z0-9][A-Z0-9._-]{2,63}$"},
          "type": {"type": "string", "enum": ["budget", "deadline", "technical", "data", "security", "privacy", "legal", "regulatory", "operational", "strategic", "other"]},
          "description": {"type": "string", "minLength": 1, "maxLength": 2000}
        }
      }
    },
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "actorRef": {"type": "string", "pattern": "^(human|agent|kernel|verifier|platform):[A-Za-z0-9][A-Za-z0-9._@+:/-]{1,127}$"},
    "party": {
      "type": "object",
      "additionalProperties": false,
      "required": ["segment", "description", "usage_context"],
      "properties": {
        "segment": {"type": "string", "minLength": 1, "maxLength": 500},
        "description": {"type": "string", "minLength": 1, "maxLength": 2000},
        "usage_context": {"type": "string", "minLength": 1, "maxLength": 2000}
      }
    }
  }
}
