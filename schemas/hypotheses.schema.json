{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tempo.local/schemas/hypotheses.schema.json",
  "title": "TEMPO Ranked Hypothesis Set",
  "description": "Ranked, falsifiable business hypotheses. The kernel enforces unique ranks and exactly one rank-1 uncertainty; the human owner remains responsible for choosing which uncertainty is highest risk.",
  "type": "object",
  "additionalProperties": false,
  "required": ["hypothesis_set_id", "version", "opportunity_ref", "owner", "review_at", "hypotheses", "created_at", "updated_at"],
  "properties": {
    "hypothesis_set_id": {"type": "string", "pattern": "^HS-[A-Z0-9][A-Z0-9._-]{2,63}$"},
    "version": {"type": "integer", "minimum": 1},
    "opportunity_ref": {"type": "string", "pattern": "^O-[A-Z0-9][A-Z0-9._-]{2,63}$"},
    "owner": {"$ref": "#/$defs/actorRef"},
    "review_at": {"type": "string", "format": "date-time"},
    "hypotheses": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/hypothesis"},
      "contains": {
        "type": "object",
        "required": ["rank"],
        "properties": {"rank": {"const": 1}}
      },
      "minContains": 1,
      "maxContains": 1
    },
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "actorRef": {"type": "string", "pattern": "^(human|agent|kernel|verifier|platform):[A-Za-z0-9][A-Za-z0-9._@+:/-]{1,127}$"},
    "evidenceRef": {"type": "string", "pattern": "^E-[A-Z0-9][A-Z0-9._-]{2,63}$"},
    "confidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["score", "scale", "rationale"],
      "properties": {
        "score": {"type": "integer", "minimum": 0, "maximum": 100},
        "scale": {"const": "0-100"},
        "rationale": {"type": "string", "minLength": 1, "maxLength": 1000}
      }
    },
    "evidenceThreshold": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metric", "aggregation", "operator", "target", "unit", "minimum_evidence_items", "required_source_types"],
      "properties": {
        "metric": {"type": "string", "minLength": 1, "maxLength": 500},
        "aggregation": {"type": "string", "enum": ["sum", "count", "mean", "minimum", "maximum", "latest", "any", "all"]},
        "operator": {"type": "string", "enum": [">", ">=", "<", "<=", "==", "!=", "contains", "not_contains"]},
        "target": {"type": ["string", "number", "integer", "boolean"]},
        "unit": {"type": "string", "minLength": 1, "maxLength": 100},
        "minimum_evidence_items": {"type": "integer", "minimum": 1},
        "required_source_types": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 100}
        }
      }
    },
    "killOrPivot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "condition", "reason_code"],
      "properties": {
        "action": {"type": "string", "enum": ["kill", "pivot"]},
        "condition": {"type": "string", "minLength": 12, "maxLength": 2000},
        "reason_code": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]{2,63}$"}
      }
    },
    "hypothesis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hypothesis_id",
        "rank",
        "type",
        "statement",
        "why_it_matters",
        "falsification_condition",
        "evidence_threshold",
        "kill_or_pivot_trigger",
        "status",
        "evidence_refs",
        "confidence",
        "owner",
        "review_at"
      ],
      "properties": {
        "hypothesis_id": {"type": "string", "pattern": "^H-[A-Z0-9][A-Z0-9._-]{2,63}$"},
        "rank": {"type": "integer", "minimum": 1},
        "type": {
          "type": "string",
          "enum": ["problem", "target_user", "economic_buyer", "desirability", "value", "willingness_to_pay", "revenue_or_roi", "distribution", "adoption", "differentiation", "technical_feasibility", "data", "cost", "security", "privacy", "legal", "regulatory", "strategic_fit"]
        },
        "statement": {"type": "string", "minLength": 12, "maxLength": 2000},
        "why_it_matters": {"type": "string", "minLength": 1, "maxLength": 2000},
        "falsification_condition": {"type": "string", "minLength": 12, "maxLength": 2000},
        "evidence_threshold": {"$ref": "#/$defs/evidenceThreshold"},
        "kill_or_pivot_trigger": {"$ref": "#/$defs/killOrPivot"},
        "status": {"type": "string", "enum": ["untested", "testing", "supported", "contradicted", "falsified", "expired", "inconclusive"]},
        "evidence_refs": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/evidenceRef"}},
        "confidence": {"$ref": "#/$defs/confidence"},
        "owner": {"$ref": "#/$defs/actorRef"},
        "review_at": {"type": "string", "format": "date-time"},
        "expires_at": {"type": "string", "format": "date-time"}
      }
    }
  }
}
