{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tempo.local/schemas/mvp-charter.schema.json",
  "title": "TEMPO MVP Charter",
  "description": "Human-owned charter binding a commercial decision to the smallest governed product experiment that can resolve it.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mvp_id",
    "version",
    "state",
    "opportunity_ref",
    "decision_question_ref",
    "decision_to_unlock",
    "hypothesis_refs",
    "evidence_baseline",
    "d0_user_journey",
    "in_scope",
    "out_of_scope",
    "success_metrics",
    "kill_and_pivot_triggers",
    "budget_cap",
    "deadline",
    "owner",
    "technical_boundaries",
    "data_boundaries",
    "supported_audience",
    "supported_environment",
    "implementation_risk_tier",
    "allowed_lanes",
    "demo_beats",
    "post_mvp_decision_meeting",
    "rollback_or_disposal_plan",
    "created_at",
    "updated_at",
    "signed_by",
    "signed_at"
  ],
  "properties": {
    "mvp_id": {"type": "string", "pattern": "^M-[A-Z0-9][A-Z0-9._-]{2,63}$"},
    "version": {"type": "integer", "minimum": 1},
    "state": {"type": "string", "enum": ["draft", "signed", "superseded", "revoked"]},
    "opportunity_ref": {"type": "string", "pattern": "^O-[A-Z0-9][A-Z0-9._-]{2,63}$"},
    "decision_question_ref": {"type": "string", "pattern": "^O-[A-Z0-9][A-Z0-9._-]{2,63}#/decision_question$"},
    "decision_to_unlock": {"type": "string", "minLength": 12, "maxLength": 2000},
    "hypothesis_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^H-[A-Z0-9][A-Z0-9._-]{2,63}$"}
    },
    "evidence_baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifest_ref", "manifest_hash", "evidence_refs", "captured_at"],
      "properties": {
        "manifest_ref": {"const": "plan/evidence/manifest.jsonl"},
        "manifest_hash": {"$ref": "#/$defs/hash"},
        "evidence_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^E-[A-Z0-9][A-Z0-9._-]{2,63}$"}},
        "captured_at": {"type": "string", "format": "date-time"}
      }
    },
    "d0_user_journey": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step_id", "order", "actor", "action", "observable_result"],
        "properties": {
          "step_id": {"type": "string", "pattern": "^J-[A-Z0-9][A-Z0-9._-]{2,63}$"},
          "order": {"type": "integer", "minimum": 1},
          "actor": {"type": "string", "minLength": 1, "maxLength": 500},
          "action": {"type": "string", "minLength": 1, "maxLength": 1000},
          "observable_result": {"type": "string", "minLength": 1, "maxLength": 1000}
        }
      }
    },
    "in_scope": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/pathGlob"}},
    "out_of_scope": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 1000}},
    "success_metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["metric_id", "name", "operator", "threshold", "unit", "measurement_method"],
        "properties": {
          "metric_id": {"type": "string", "pattern": "^SM-[A-Z0-9][A-Z0-9._-]{2,63}$"},
          "name": {"type": "string", "minLength": 1, "maxLength": 500},
          "operator": {"type": "string", "enum": [">", ">=", "<", "<=", "==", "!="]},
          "threshold": {"type": ["number", "integer", "string", "boolean"]},
          "unit": {"type": "string", "minLength": 1, "maxLength": 100},
          "measurement_method": {"type": "string", "minLength": 1, "maxLength": 2000}
        }
      }
    },
    "kill_and_pivot_triggers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["trigger_id", "action", "condition", "reason_code"],
        "properties": {
          "trigger_id": {"type": "string", "pattern": "^KP-[A-Z0-9][A-Z0-9._-]{2,63}$"},
          "action": {"type": "string", "enum": ["kill", "pivot"]},
          "condition": {"type": "string", "minLength": 12, "maxLength": 2000},
          "reason_code": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]{2,63}$"}
        }
      }
    },
    "budget_cap": {"$ref": "#/$defs/money"},
    "deadline": {"type": "string", "format": "date-time"},
    "owner": {"$ref": "#/$defs/actorRef"},
    "technical_boundaries": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1, "maxLength": 1000}},
    "data_boundaries": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1, "maxLength": 1000}},
    "supported_audience": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 500}},
    "supported_environment": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 500}},
    "implementation_risk_tier": {"type": "string", "enum": ["R0", "R1", "R2"]},
    "allowed_lanes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z][a-z0-9_-]{1,63}$"}},
    "demo_beats": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["beat_id", "order", "demo_tier", "description", "acceptance"],
        "properties": {
          "beat_id": {"type": "string", "pattern": "^B-[A-Z0-9][A-Z0-9._-]{2,63}$"},
          "order": {"type": "integer", "minimum": 1},
          "demo_tier": {"type": "string", "enum": ["D0", "D1", "D2", "D3"]},
          "description": {"type": "string", "minLength": 1, "maxLength": 1000},
          "acceptance": {"type": "string", "minLength": 12, "maxLength": 2000}
        }
      },
      "contains": {
        "type": "object",
        "required": ["demo_tier"],
        "properties": {"demo_tier": {"const": "D0"}}
      },
      "minContains": 1
    },
    "post_mvp_decision_meeting": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scheduled_at", "owner", "required_participants", "decision_question"],
      "properties": {
        "scheduled_at": {"type": "string", "format": "date-time"},
        "owner": {"$ref": "#/$defs/actorRef"},
        "required_participants": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/actorRef"}},
        "decision_question": {"type": "string", "minLength": 12, "maxLength": 2000}
      }
    },
    "rollback_or_disposal_plan": {"type": "string", "minLength": 12, "maxLength": 3000},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "signed_by": {"type": ["string", "null"], "pattern": "^(human|platform):[A-Za-z0-9][A-Za-z0-9._@+:/-]{1,127}$"},
    "signed_at": {"type": ["string", "null"], "format": "date-time"}
  },
  "allOf": [
    {
      "if": {
        "properties": {"state": {"const": "signed"}},
        "required": ["state"]
      },
      "then": {
        "properties": {
          "signed_by": {"type": "string"},
          "signed_at": {"type": "string", "format": "date-time"}
        }
      }
    }
  ],
  "$defs": {
    "actorRef": {"type": "string", "pattern": "^(human|agent|kernel|verifier|platform):[A-Za-z0-9][A-Za-z0-9._@+:/-]{1,127}$"},
    "hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "pathGlob": {"type": "string", "pattern": "^(?![A-Za-z]:)(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\\u0000]+$", "maxLength": 500},
    "money": {
      "type": "object",
      "additionalProperties": false,
      "required": ["amount", "currency"],
      "properties": {
        "amount": {"type": "number", "minimum": 0},
        "currency": {"type": "string", "pattern": "^[A-Z]{3}$"}
      }
    }
  }
}
