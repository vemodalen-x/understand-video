{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tempo.local/schemas/readiness-policy.schema.json",
  "title": "TEMPO MVP Readiness Policy",
  "description": "Human-owned policy snapshot. Hard blockers are evaluated before weighted dimensions; a high aggregate cannot override a blocker or floor failure.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "policy_id",
    "version",
    "state",
    "effective_at",
    "owner",
    "approved_by",
    "approved_at",
    "hard_blockers",
    "weights",
    "floors",
    "aggregate_threshold",
    "external_evidence",
    "cheaper_experiment_types"
  ],
  "properties": {
    "policy_id": {"type": "string", "pattern": "^RP-[A-Z0-9][A-Z0-9._-]{2,63}$"},
    "version": {"type": "integer", "minimum": 1},
    "state": {"type": "string", "enum": ["draft", "signed", "superseded", "revoked"]},
    "effective_at": {"type": "string", "format": "date-time"},
    "owner": {"$ref": "#/$defs/actorRef"},
    "approved_by": {"type": ["string", "null"], "pattern": "^(human|platform):[A-Za-z0-9][A-Za-z0-9._@+:/-]{1,127}$"},
    "approved_at": {"type": ["string", "null"], "format": "date-time"},
    "hard_blockers": {
      "type": "array",
      "minItems": 19,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["blocker_id", "reason_code", "description"],
        "properties": {
          "blocker_id": {"type": "string", "enum": ["B01", "B02", "B03", "B04", "B05", "B06", "B07", "B08", "B09", "B10", "B11", "B12", "B13", "B14", "B15", "B16", "B17", "B18", "B19"]},
          "reason_code": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]{2,63}$"},
          "description": {"type": "string", "minLength": 1, "maxLength": 2000}
        }
      }
    },
    "weights": {"$ref": "#/$defs/dimensions"},
    "floors": {"$ref": "#/$defs/dimensions"},
    "aggregate_threshold": {"type": "number", "minimum": 0, "maximum": 100},
    "external_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minimum_items", "model_generated_counts_as_external", "require_contradictions_acknowledged"],
      "properties": {
        "minimum_items": {"type": "integer", "minimum": 1},
        "model_generated_counts_as_external": {"const": false},
        "require_contradictions_acknowledged": {"const": true}
      }
    },
    "cheaper_experiment_types": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "enum": ["interview", "landing_page_test", "concierge_workflow", "manual_service", "clickable_prototype", "api_feasibility_spike", "benchmark", "pricing_test", "data_availability_check"]}
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"state": {"const": "signed"}},
        "required": ["state"]
      },
      "then": {
        "properties": {
          "approved_by": {"type": "string"},
          "approved_at": {"type": "string", "format": "date-time"}
        }
      }
    }
  ],
  "$defs": {
    "actorRef": {"type": "string", "pattern": "^(human|agent|kernel|verifier|platform):[A-Za-z0-9][A-Za-z0-9._@+:/-]{1,127}$"},
    "dimensions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["problem_evidence", "target_segment_clarity", "desirability", "economic_value", "distribution_feasibility", "differentiation", "technical_feasibility", "evidence_quality", "expected_decision_value", "implementation_cost", "strategic_fit", "risk_exposure"],
      "properties": {
        "problem_evidence": {"type": "number", "minimum": 0, "maximum": 100},
        "target_segment_clarity": {"type": "number", "minimum": 0, "maximum": 100},
        "desirability": {"type": "number", "minimum": 0, "maximum": 100},
        "economic_value": {"type": "number", "minimum": 0, "maximum": 100},
        "distribution_feasibility": {"type": "number", "minimum": 0, "maximum": 100},
        "differentiation": {"type": "number", "minimum": 0, "maximum": 100},
        "technical_feasibility": {"type": "number", "minimum": 0, "maximum": 100},
        "evidence_quality": {"type": "number", "minimum": 0, "maximum": 100},
        "expected_decision_value": {"type": "number", "minimum": 0, "maximum": 100},
        "implementation_cost": {"type": "number", "minimum": 0, "maximum": 100},
        "strategic_fit": {"type": "number", "minimum": 0, "maximum": 100},
        "risk_exposure": {"type": "number", "minimum": 0, "maximum": 100}
      }
    }
  }
}
