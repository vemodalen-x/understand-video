{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tempo.local/schemas/decision-brief.schema.json",
  "title": "TEMPO Human Decision Brief",
  "description": "Human-owned decision record. A provider recommendation may be cited but can never populate the approval fields.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision_brief_id",
    "version",
    "opportunity_ref",
    "state",
    "recommendation",
    "rationale",
    "acknowledged_counterevidence_refs",
    "projected_experiment_cost",
    "cheaper_sufficient_experiment",
    "owner",
    "approved_by",
    "approved_at",
    "signing_provenance",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "decision_brief_id": {"type": "string", "pattern": "^DB-[A-Z0-9][A-Z0-9._-]{2,63}$"},
    "version": {"type": "integer", "minimum": 1},
    "opportunity_ref": {"type": "string", "pattern": "^O-[A-Z0-9][A-Z0-9._-]{2,63}$"},
    "state": {"type": "string", "enum": ["draft", "signed", "superseded", "revoked"]},
    "recommendation": {"type": "string", "enum": ["MVP", "EXPERIMENT", "PIVOT", "KILL"]},
    "rationale": {"type": "string", "minLength": 12, "maxLength": 3000},
    "acknowledged_counterevidence_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^E-[A-Z0-9][A-Z0-9._-]{2,63}$"}
    },
    "projected_experiment_cost": {"$ref": "#/$defs/money"},
    "cheaper_sufficient_experiment": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["action_id", "type", "description", "decision_to_unlock", "estimated_cost", "deadline"],
      "properties": {
        "action_id": {"type": "string", "pattern": "^X-[A-Z0-9][A-Z0-9._-]{2,63}$"},
        "type": {"type": "string", "enum": ["interview", "landing_page_test", "concierge_workflow", "manual_service", "clickable_prototype", "api_feasibility_spike", "benchmark", "pricing_test", "data_availability_check", "mvp"]},
        "description": {"type": "string", "minLength": 1, "maxLength": 2000},
        "decision_to_unlock": {"type": "string", "minLength": 12, "maxLength": 2000},
        "estimated_cost": {"$ref": "#/$defs/money"},
        "deadline": {"type": "string", "format": "date-time"}
      }
    },
    "owner": {"$ref": "#/$defs/actorRef"},
    "approved_by": {"type": ["string", "null"], "pattern": "^(human|platform):[A-Za-z0-9][A-Za-z0-9._@+:/-]{1,127}$"},
    "approved_at": {"type": ["string", "null"], "format": "date-time"},
    "signing_provenance": {"type": ["string", "null"], "enum": ["tty_human", "external_signer", "demo_fixture", null]},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"}
  },
  "allOf": [
    {
      "if": {"properties": {"state": {"const": "signed"}}, "required": ["state"]},
      "then": {
        "properties": {
          "approved_by": {"type": "string"},
          "approved_at": {"type": "string", "format": "date-time"},
          "signing_provenance": {"type": "string"}
        }
      }
    },
    {
      "if": {"properties": {"signing_provenance": {"const": "demo_fixture"}}, "required": ["signing_provenance"]},
      "then": {"properties": {"approved_by": {"const": "platform:demo-fixture-signer"}}}
    }
  ],
  "$defs": {
    "actorRef": {"type": "string", "pattern": "^(human|agent|kernel|verifier|platform):[A-Za-z0-9][A-Za-z0-9._@+:/-]{1,127}$"},
    "money": {
      "type": "object",
      "additionalProperties": false,
      "required": ["amount", "currency"],
      "properties": {
        "amount": {"type": "number", "minimum": 0},
        "currency": {"type": "string", "pattern": "^[A-Z]{3}$"}
      }
    }
  }
}
