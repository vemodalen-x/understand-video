{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tempo.local/schemas/assessment.schema.json",
  "title": "TEMPO Deterministic MVP Readiness Assessment",
  "description": "Machine output from the readiness evaluator. MVP_AUTHORIZED means eligible for a human warrant decision; it does not itself authorize implementation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "assessment_id",
    "engine_version",
    "assessed_at",
    "assessor",
    "policy_ref",
    "opportunity_ref",
    "business_model_ref",
    "hypothesis_set_ref",
    "evidence_manifest_ref",
    "charter_ref",
    "primary_outcome",
    "evaluation_mode",
    "authorization_ceiling",
    "eligible_for_authorization",
    "authorization_valid",
    "build_allowed",
    "hard_blockers",
    "dimension_scores",
    "weighted_score",
    "floor_failures",
    "contradictory_evidence_refs",
    "rank_one_threshold",
    "reasons",
    "cheapest_next_action",
    "input_hashes",
    "assessment_hash",
    "resulting_business_state"
  ],
  "properties": {
    "assessment_id": {"type": "string", "pattern": "^A-[A-Z0-9][A-Z0-9._-]{2,63}$"},
    "engine_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][A-Za-z0-9.-]+)?$"},
    "assessed_at": {"type": "string", "format": "date-time"},
    "assessor": {"type": "string", "pattern": "^kernel:[A-Za-z0-9][A-Za-z0-9._/-]{1,127}$"},
    "policy_ref": {"type": "string", "pattern": "^RP-[A-Z0-9][A-Z0-9._-]{2,63}$"},
    "opportunity_ref": {"type": ["string", "null"], "pattern": "^O-[A-Z0-9][A-Z0-9._-]{2,63}$"},
    "business_model_ref": {"type": ["string", "null"], "pattern": "^BM-[A-Z0-9][A-Z0-9._-]{2,63}$"},
    "hypothesis_set_ref": {"type": ["string", "null"], "pattern": "^HS-[A-Z0-9][A-Z0-9._-]{2,63}$"},
    "evidence_manifest_ref": {
      "oneOf": [
        {"const": "plan/evidence/manifest.jsonl"},
        {"type": "null"}
      ]
    },
    "charter_ref": {"type": ["string", "null"], "pattern": "^M-[A-Z0-9][A-Z0-9._-]{2,63}$"},
    "primary_outcome": {"type": "string", "enum": ["MVP_AUTHORIZED", "EXPERIMENT_REQUIRED", "PIVOT_REQUIRED", "KILL_RECOMMENDED", "BLOCKED_INVALID_INPUT"]},
    "evaluation_mode": {"type": "string", "enum": ["standard", "fixture_demo"]},
    "authorization_ceiling": {
      "type": "string",
      "enum": ["human_warrant", "demo_only"],
      "description": "The strongest warrant class this assessment may support, independent of readiness outcome."
    },
    "eligible_for_authorization": {"type": "boolean"},
    "authorization_valid": {"type": "boolean"},
    "build_allowed": {
      "type": "boolean",
      "description": "True only when readiness passed and a separate current human warrant is valid. A readiness recommendation alone must leave this false."
    },
    "hard_blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["blocker_id", "reason_code", "message", "artifact_ref"],
        "properties": {
          "blocker_id": {"type": "string", "pattern": "^B(?:0[1-9]|1[0-9])$"},
          "reason_code": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]{2,63}$"},
          "message": {"type": "string", "minLength": 1, "maxLength": 2000},
          "artifact_ref": {"type": "string", "minLength": 1, "maxLength": 500}
        }
      }
    },
    "dimension_scores": {"$ref": "#/$defs/dimensions"},
    "weighted_score": {"type": "number", "minimum": 0, "maximum": 100},
    "floor_failures": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "enum": ["problem_evidence", "target_segment_clarity", "desirability", "economic_value", "distribution_feasibility", "differentiation", "technical_feasibility", "evidence_quality", "expected_decision_value", "implementation_cost", "strategic_fit", "risk_exposure"]}
    },
    "contradictory_evidence_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^E-[A-Z0-9][A-Z0-9._-]{2,63}$"}},
    "rank_one_threshold": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hypothesis_ref", "metric", "aggregation", "operator", "target", "observed", "unit", "minimum_evidence_items", "matching_evidence_refs", "missing_source_types", "status"],
      "properties": {
        "hypothesis_ref": {"type": ["string", "null"], "pattern": "^H-[A-Z0-9][A-Z0-9._-]{2,63}$"},
        "metric": {"type": ["string", "null"], "maxLength": 500},
        "aggregation": {"type": ["string", "null"], "enum": ["sum", "count", "mean", "minimum", "maximum", "latest", "any", "all", null]},
        "operator": {"type": ["string", "null"], "enum": [">", ">=", "<", "<=", "==", "!=", "contains", "not_contains", null]},
        "target": {"type": ["string", "number", "integer", "boolean", "null"]},
        "observed": {"type": ["string", "number", "integer", "boolean", "null"]},
        "unit": {"type": ["string", "null"], "maxLength": 100},
        "minimum_evidence_items": {"type": "integer", "minimum": 0},
        "matching_evidence_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^E-[A-Z0-9][A-Z0-9._-]{2,63}$"}},
        "missing_source_types": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 100}},
        "status": {"type": "string", "enum": ["passed", "not_reached", "insufficient_measurement", "invalid_measurement", "not_evaluated"]}
      }
    },
    "reasons": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1, "maxLength": 1000}},
    "cheapest_next_action": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "#/$defs/nextAction"}
      ]
    },
    "input_hashes": {
      "type": "array",
      "minItems": 0,
      "items": {"$ref": "#/$defs/hashBinding"}
    },
    "assessment_hash": {"$ref": "#/$defs/hash"},
    "resulting_business_state": {
      "type": "string",
      "enum": ["DRAFT", "DISCOVERY", "VALIDATING", "MVP_CANDIDATE", "MVP_AUTHORIZED", "EXPERIMENT_REQUIRED", "PIVOTED", "KILLED"]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"build_allowed": {"const": true}},
        "required": ["build_allowed"]
      },
      "then": {
        "properties": {
          "primary_outcome": {"const": "MVP_AUTHORIZED"},
          "eligible_for_authorization": {"const": true},
          "authorization_valid": {"const": true}
        }
      }
    },
    {
      "if": {
        "properties": {"evaluation_mode": {"const": "fixture_demo"}},
        "required": ["evaluation_mode"]
      },
      "then": {"properties": {"authorization_ceiling": {"const": "demo_only"}}}
    },
    {
      "if": {
        "properties": {"evaluation_mode": {"const": "standard"}},
        "required": ["evaluation_mode"]
      },
      "then": {"properties": {"authorization_ceiling": {"const": "human_warrant"}}}
    }
  ],
  "$defs": {
    "hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "hashBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_ref", "hash"],
      "properties": {
        "artifact_ref": {"type": "string", "minLength": 1, "maxLength": 500},
        "hash": {"$ref": "#/$defs/hash"}
      }
    },
    "dimensions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["problem_evidence", "target_segment_clarity", "desirability", "economic_value", "distribution_feasibility", "differentiation", "technical_feasibility", "evidence_quality", "expected_decision_value", "implementation_cost", "strategic_fit", "risk_exposure"],
      "properties": {
        "problem_evidence": {"type": "number", "minimum": 0, "maximum": 100},
        "target_segment_clarity": {"type": "number", "minimum": 0, "maximum": 100},
        "desirability": {"type": "number", "minimum": 0, "maximum": 100},
        "economic_value": {"type": "number", "minimum": 0, "maximum": 100},
        "distribution_feasibility": {"type": "number", "minimum": 0, "maximum": 100},
        "differentiation": {"type": "number", "minimum": 0, "maximum": 100},
        "technical_feasibility": {"type": "number", "minimum": 0, "maximum": 100},
        "evidence_quality": {"type": "number", "minimum": 0, "maximum": 100},
        "expected_decision_value": {"type": "number", "minimum": 0, "maximum": 100},
        "implementation_cost": {"type": "number", "minimum": 0, "maximum": 100},
        "strategic_fit": {"type": "number", "minimum": 0, "maximum": 100},
        "risk_exposure": {"type": "number", "minimum": 0, "maximum": 100}
      }
    },
    "money": {
      "type": "object",
      "additionalProperties": false,
      "required": ["amount", "currency"],
      "properties": {
        "amount": {"type": "number", "minimum": 0},
        "currency": {"type": "string", "pattern": "^[A-Z]{3}$"}
      }
    },
    "nextAction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_id", "type", "description", "decision_to_unlock", "estimated_cost", "deadline"],
      "properties": {
        "action_id": {"type": "string", "pattern": "^X-[A-Z0-9][A-Z0-9._-]{2,63}$"},
        "type": {"type": "string", "enum": ["interview", "landing_page_test", "concierge_workflow", "manual_service", "clickable_prototype", "api_feasibility_spike", "benchmark", "pricing_test", "data_availability_check", "revise_input", "pivot", "stop"]},
        "description": {"type": "string", "minLength": 1, "maxLength": 2000},
        "decision_to_unlock": {"type": "string", "minLength": 1, "maxLength": 2000},
        "estimated_cost": {"$ref": "#/$defs/money"},
        "deadline": {"type": "string", "format": "date-time"}
      }
    }
  }
}
