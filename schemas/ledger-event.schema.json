{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tempo.local/schemas/ledger-event.schema.json",
  "title": "TEMPO Append-only Ledger Event",
  "description": "One JSON object per line in .tempo/ledger.jsonl. Tooling enforces sequence monotonicity and the previous_hash/event_hash chain.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "event_type",
    "sequence",
    "timestamp",
    "actor",
    "session",
    "relevant_ids",
    "artifact_hashes",
    "evidence_refs",
    "reason_code",
    "resulting_state",
    "details",
    "previous_hash",
    "event_hash"
  ],
  "properties": {
    "event_id": {"type": "string", "pattern": "^EVT-[A-F0-9]{32}$"},
    "event_type": {
      "type": "string",
      "enum": [
        "opportunity_created",
        "commercial_proposal_imported",
        "hypothesis_ranked",
        "evidence_added",
        "evidence_rejected",
        "evidence_expired",
        "readiness_assessed",
        "experiment_required",
        "mvp_charter_drafted",
        "mvp_charter_signed",
        "mvp_authorized",
        "mvp_authorization_revoked",
        "mvp_authorization_expired",
        "mvp_authorization_invalidated",
        "mvp_start_blocked",
        "mvp_started",
        "scope_changed",
        "budget_changed",
        "verification_completed",
        "hypothesis_threshold_reached",
        "hypothesis_falsified",
        "verdict_compiled",
        "human_verdict_recorded"
      ]
    },
    "sequence": {"type": "integer", "minimum": 1},
    "timestamp": {"type": "string", "format": "date-time"},
    "actor": {"$ref": "#/$defs/actorRef"},
    "session": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{2,255}$"},
    "relevant_ids": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"$ref": "#/$defs/stableRef"}
    },
    "artifact_hashes": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/hash"}
    },
    "evidence_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^E-[A-Z0-9][A-Z0-9._-]{2,63}$"}
    },
    "reason_code": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]{2,63}$"},
    "resulting_state": {
      "type": "string",
      "enum": [
        "UNCHANGED",
        "DRAFT",
        "DISCOVERY",
        "VALIDATING",
        "MVP_CANDIDATE",
        "MVP_AUTHORIZED",
        "EXPERIMENT_REQUIRED",
        "PIVOTED",
        "KILLED",
        "NOT_AUTHORIZED",
        "AUTHORIZED",
        "BUILDING",
        "DEMO_GREEN",
        "PILOT_READY",
        "VERDICT_RECORDED",
        "REVOKED",
        "EXPIRED"
      ]
    },
    "details": {
      "type": "object",
      "maxProperties": 100,
      "additionalProperties": {"$ref": "#/$defs/detailValue"}
    },
    "previous_hash": {"$ref": "#/$defs/hash"},
    "event_hash": {"$ref": "#/$defs/hash"}
  },
  "$defs": {
    "actorRef": {"type": "string", "pattern": "^(human|agent|kernel|verifier|platform):[A-Za-z0-9][A-Za-z0-9._@+:/-]{1,127}$"},
    "hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "stableRef": {
      "type": "string",
      "pattern": "^(?:[A-Z][A-Z0-9]{0,7}-[A-Z0-9][A-Z0-9._-]{2,127}|git:[0-9a-f]{7,64})$"
    },
    "detailValue": {
      "oneOf": [
        {"type": "string", "maxLength": 4000},
        {"type": "number"},
        {"type": "boolean"},
        {"type": "null"},
        {
          "type": "array",
          "maxItems": 100,
          "items": {"$ref": "#/$defs/detailValue"}
        },
        {
          "type": "object",
          "maxProperties": 100,
          "additionalProperties": {"$ref": "#/$defs/detailValue"}
        }
      ]
    }
  }
}
