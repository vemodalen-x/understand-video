{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tempo.local/schemas/business-model.schema.json",
  "title": "TEMPO Business Model Proposal",
  "description": "A hypothesis-bearing business model. Validation state never grants implementation authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "business_model_id",
    "version",
    "opportunity_ref",
    "state",
    "value_proposition",
    "target_segment",
    "target_user",
    "economic_buyer",
    "willingness_to_pay_or_internal_roi_hypothesis",
    "revenue_or_economic_value_model",
    "acquisition_distribution_hypothesis",
    "adoption_friction",
    "key_partners_or_dependencies",
    "rough_cost_drivers",
    "alternatives_and_differentiation",
    "defensibility_hypothesis",
    "material_risks",
    "hypothesis_refs",
    "evidence_refs",
    "owner",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "business_model_id": {"type": "string", "pattern": "^BM-[A-Z0-9][A-Z0-9._-]{2,63}$"},
    "version": {"type": "integer", "minimum": 1},
    "opportunity_ref": {"type": "string", "pattern": "^O-[A-Z0-9][A-Z0-9._-]{2,63}$"},
    "state": {"type": "string", "enum": ["draft", "validating", "supported", "contradicted", "rejected", "superseded"]},
    "value_proposition": {"type": "string", "minLength": 12, "maxLength": 3000},
    "target_segment": {"type": "string", "minLength": 1, "maxLength": 1000},
    "target_user": {"$ref": "#/$defs/party"},
    "economic_buyer": {"$ref": "#/$defs/party"},
    "willingness_to_pay_or_internal_roi_hypothesis": {"type": "string", "minLength": 12, "maxLength": 2000},
    "revenue_or_economic_value_model": {"type": "string", "minLength": 12, "maxLength": 2000},
    "acquisition_distribution_hypothesis": {"type": "string", "minLength": 12, "maxLength": 2000},
    "adoption_friction": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1, "maxLength": 1000}
    },
    "key_partners_or_dependencies": {
      "type": "array",
      "items": {"type": "string", "minLength": 1, "maxLength": 1000}
    },
    "rough_cost_drivers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["driver", "basis", "uncertainty"],
        "properties": {
          "driver": {"type": "string", "minLength": 1, "maxLength": 500},
          "basis": {"type": "string", "minLength": 1, "maxLength": 1000},
          "uncertainty": {"type": "string", "enum": ["low", "medium", "high", "unknown"]}
        }
      }
    },
    "alternatives_and_differentiation": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["alternative", "differentiation"],
        "properties": {
          "alternative": {"type": "string", "minLength": 1, "maxLength": 1000},
          "differentiation": {"type": "string", "minLength": 1, "maxLength": 2000}
        }
      }
    },
    "defensibility_hypothesis": {"type": "string", "minLength": 1, "maxLength": 2000},
    "material_risks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["risk_id", "category", "description", "resolution_status"],
        "properties": {
          "risk_id": {"type": "string", "pattern": "^BR-[A-Z0-9][A-Z0-9._-]{2,63}$"},
          "category": {"type": "string", "enum": ["regulatory", "privacy", "security", "legal", "trust", "operational", "market", "technical", "financial"]},
          "description": {"type": "string", "minLength": 1, "maxLength": 2000},
          "resolution_status": {"type": "string", "enum": ["open", "mitigated", "accepted_by_human", "resolved"]}
        }
      }
    },
    "hypothesis_refs": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/hypothesisRef"}},
    "evidence_refs": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/evidenceRef"}},
    "owner": {"$ref": "#/$defs/actorRef"},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "actorRef": {"type": "string", "pattern": "^(human|agent|kernel|verifier|platform):[A-Za-z0-9][A-Za-z0-9._@+:/-]{1,127}$"},
    "hypothesisRef": {"type": "string", "pattern": "^H-[A-Z0-9][A-Z0-9._-]{2,63}$"},
    "evidenceRef": {"type": "string", "pattern": "^E-[A-Z0-9][A-Z0-9._-]{2,63}$"},
    "party": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description", "value_or_need"],
      "properties": {
        "description": {"type": "string", "minLength": 1, "maxLength": 1500},
        "value_or_need": {"type": "string", "minLength": 1, "maxLength": 1500}
      }
    }
  }
}
